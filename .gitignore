db_conn.php

# --- Local environment ---
.env
*.env.local

# --- XAMPP / PHP logs ---
*.log
error_log

# --- OS files ---
.DS_Store
Thumbs.db
desktop.ini

# --- Editor folders ---
.vscode/
.idea/
*.suo
*.user

# --- Composer (if used) ---
vendor/
composer.lock
